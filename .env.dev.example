DEV_POSTGRES_PASSWORD=replace-with-a-different-long-random-password
DEV_APP_ENCRYPTION_KEY=replace-with-a-different-openssl-rand-base64-32-output
JELLYFIN_CONTAINER_NAME=jellyfin
# Development uses the normal port and is reachable by a separate Caddy host.
# Do not run production and development at the same time with this configuration.
DEV_APP_BIND_ADDRESS=0.0.0.0
DEV_APP_PORT=3000
# Keep true when accessing development through the existing Caddy HTTPS address.
# Change to false only for direct http:// access on a trusted LAN.
DEV_SESSION_COOKIE_SECURE=true
