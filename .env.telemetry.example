TELEMETRY_AGENT_TOKEN=replace-with-openssl-rand-hex-32-output
# Use :develop while testing; released installations default to :latest.
# JELLYPULSE_IMAGE=ghcr.io/sleepingpanda4/jellypulse:develop
JELLYFIN_CONTAINER_NAME=jellyfin
# Bind to the Jellyfin host's LAN address so only that interface publishes the agent.
TELEMETRY_AGENT_BIND_ADDRESS=127.0.0.1
TELEMETRY_AGENT_PORT=9469
# If Jellyfin is not a Docker container, report whole-host CPU/RAM instead.
TELEMETRY_HOST_FALLBACK=true
# Optional Prometheus GPU exporter reachable from the agent container.
# GPU_METRICS_URL=http://gpu-exporter:9400/metrics
# GPU_METRIC_NAME=DCGM_FI_DEV_GPU_UTIL
# GPU_METRIC_SCALE=1
# GPU_METRICS_VENDOR=NVIDIA
