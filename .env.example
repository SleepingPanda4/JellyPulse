POSTGRES_PASSWORD=replace-with-a-long-random-password
APP_ENCRYPTION_KEY=replace-with-openssl-rand-base64-32-output
JELLYFIN_CONTAINER_NAME=jellyfin
# Keep localhost unless an HTTPS reverse proxy/VPN is in front of the service.
APP_BIND_ADDRESS=127.0.0.1
# Set true only when JellyPulse is accessed through HTTPS.
SESSION_COOKIE_SECURE=false
