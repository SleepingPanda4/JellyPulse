DEV_POSTGRES_PASSWORD=replace-with-a-different-long-random-password
DEV_APP_ENCRYPTION_KEY=replace-with-a-different-openssl-rand-base64-32-output
JELLYFIN_CONTAINER_NAME=jellyfin
# Development binds to localhost on a different port from production.
DEV_APP_BIND_ADDRESS=127.0.0.1
DEV_APP_PORT=3001
# Set true only when this development instance has its own HTTPS hostname.
DEV_SESSION_COOKIE_SECURE=false
